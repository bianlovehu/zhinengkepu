# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============== LLM配置 ==============
# LLM提供商：openai / zhipu / dashscope
LLM_PROVIDER=openai

# API密钥
LLM_API_KEY=your_llm_api_key_here

# 模型名称
LLM_MODEL=DeepSeek-V3.2

# API基础URL（可选，用于代理）
LLM_BASE_URL=https://api.edgefn.net/v1

# ============== 视觉模型配置 ==============
VISION_MODEL=gpt-4o-mini
VISION_API_KEY=your_api_key_here
# VISION_BASE_URL=

# ============== Embedding配置 ==============
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://api.edgefn.net/v1

# 向量维度
EMBEDDING_DIMENSION=1536

# ============== API配置 ==============
# API认证Token
API_TOKEN=sk_customer_20260304

# 服务端口
API_HOST=0.0.0.0
API_PORT=8000

# 请求超时（秒）
API_TIMEOUT_TEXT=20
API_TIMEOUT_MULTIMODAL=30

# ============== RAG配置 ==============
# 文本分块大小
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 检索数量
TOP_K=5

# 相似度阈值
SIMILARITY_THRESHOLD=0.5

# Embedding批量大小（越大越快，BGE-M3最大支持约72条）
EMBEDDING_BATCH_SIZE=50

# 向量数据库类型：chroma / milvus / qdrant
VECTOR_DB_TYPE=chroma

# ChromaDB持久化路径
CHROMA_PERSIST_DIR=./knowledge_base/chroma_db

# ============== 会话配置 ==============
# 会话过期时间（秒）
SESSION_EXPIRE_SECONDS=3600

# 最大历史消息数
MAX_SESSION_HISTORY=20
